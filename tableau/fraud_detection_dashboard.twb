    <worksheet name='Sheet 6'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>Weekly Inflation‑Adjusted Transaction Amount Trends</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='cc_data' name='federated.0z986cu041fl781e0kt6c0t2e0yx' />
          </datasources>
          <datasource-dependencies datasource='federated.0z986cu041fl781e0kt6c0t2e0yx'>
            <column caption='Fraud Transaction' datatype='string' name='[Calculation_1223290293447335936]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [is_fraud]=0&#13;&#10;THEN &quot;No&quot;&#13;&#10;else&#13;&#10;&quot;Yes&quot; END' />
            </column>
            <column caption='Inflation-Adjusted Transaction Amounts' datatype='real' name='[Calculation_1223290293464330241]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[amt] * (1 + 0.02) ^ (YEAR(TODAY()) - YEAR([trans_date_trans_time]))' />
            </column>
            <column caption='Amt' datatype='real' name='[amt]' role='measure' type='quantitative' />
            <column caption='Category' datatype='string' name='[category]' role='dimension' type='nominal' />
            <column caption='Gender' datatype='string' name='[gender]' role='dimension' type='nominal' />
            <column caption='Is Fraud' datatype='integer' name='[is_fraud]' role='measure' type='quantitative' />
            <column-instance column='[Calculation_1223290293447335936]' derivation='None' name='[none:Calculation_1223290293447335936:nk]' pivot='key' type='nominal' />
            <column-instance column='[category]' derivation='None' name='[none:category:nk]' pivot='key' type='nominal' />
            <column-instance column='[gender]' derivation='None' name='[none:gender:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_1223290293464330241]' derivation='Sum' name='[sum:Calculation_1223290293464330241:qk]' pivot='key' type='quantitative' />
            <column-instance column='[amt]' derivation='Sum' name='[sum:amt:qk]' pivot='key' type='quantitative' />
            <column caption='Trans Date Trans Time' datatype='datetime' name='[trans_date_trans_time]' role='dimension' type='ordinal' />
            <column-instance column='[trans_date_trans_time]' derivation='Week' name='[wk:trans_date_trans_time:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <slices>
            <column>[federated.0z986cu041fl781e0kt6c0t2e0yx].[none:Calculation_1223290293447335936:nk]</column>
            <column>[federated.0z986cu041fl781e0kt6c0t2e0yx].[none:gender:nk]</column>
            <column>[federated.0z986cu041fl781e0kt6c0t2e0yx].[none:category:nk]</column>
          </slices>
          <aggregation value='true' />
        </view>
